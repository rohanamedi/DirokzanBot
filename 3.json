@client.on(events.NewMessage)
async def cevap_kontrol(event):
    """Kullanıcı cevaplarını kontrol et ve puan ver"""
    
    # Sadece gruplardaki mesajları işle
    if not event.is_group:
        return
    
    chat_id = event.chat_id
    
    # Bot aktif değilse işlem yapma
    if chat_id not in aktif_gruplar:
        return
    
    # Son soru yoksa işlem yapma
    if chat_id not in son_sorular:
        return
    
    # Mesaj boşsa veya komutla başlıyorsa işlem yapma
    if not event.message.text or event.message.text.startswith('/'):
        return
    
    # Cevabı al (A, B, C, D)
    cevap = event.message.text.strip().upper()
    
    if cevap not in ['A', 'B', 'C', 'D']:
        # Sadece A,B,C,D kabul et, diğer mesajları görmezden gel
        return
    
    # Kullanıcı daha önce bu soruya cevap vermiş mi?
    kullanici_id = event.sender_id
    if kullanici_id in son_sorular[chat_id].get('cevaplayanlar', []):
        # Daha önce cevap vermiş
        await event.reply("⚠️ Bu soruya zaten cevap verdiniz!")
        return
    
    # Doğru cevap kontrolü
    harf_to_index = {'A': 0, 'B': 1, 'C': 2, 'D': 3}
    kullanici_index = harf_to_index.get(cevap, -1)
    dogru_index = son_sorular[chat_id]['correct_index']
    
    # Cevaplayanlar listesine ekle
    if 'cevaplayanlar' not in son_sorular[chat_id]:
        son_sorular[chat_id]['cevaplayanlar'] = []
    son_sorular[chat_id]['cevaplayanlar'].append(kullanici_id)
    
    if kullanici_index == dogru_index:
        # Doğru cevap! +10 puan
        kullanici_puanlari[chat_id][kullanici_id] += 10
        
        # Kaç kişi doğru bildi sayacını güncelle
        if 'dogru_sayan' not in son_sorular[chat_id]:
            son_sorular[chat_id]['dogru_sayan'] = 0
        son_sorular[chat_id]['dogru_sayan'] += 1
        
        # Kullanıcının adını al
        isim = event.sender.first_name or "Kullanıcı"
        
        # Kullanıcıya geri bildirim
        await event.reply(f"✅ **DOĞRU!** +10 puan {isim}! 🎉")
        
        # Kullanıcının toplam puanını göster
        toplam_puan = kullanici_puanlari[chat_id][kullanici_id]
        await client.send_message(chat_id, f"👤 {isim} toplam **{toplam_puan}** puana ulaştı!")
    else:
        # Yanlış cevap
        await event.reply(f"❌ **YANLIŞ!** Doğru cevabı bekleyin. {event.sender.first_name}")

async def main():
    """Ana fonksiyon"""
    print("🚀 Dîrokzan Bot başlatılıyor...")
    print(f"📚 {len(TUM_SORULAR)} tarih sorusu yüklendi")
    print(f"🤖 Bot: @DirokzanBot")
    print("📢 Herkesin kullanımına açık!")
    print("⏱️  5 dakikada bir soru gönderecek")
    print("-" * 40)
    
    # Botu başlat
    await client.start()
    print("✅ Bot başarıyla başlatıldı!")
    print("📡 Mesajlar dinleniyor...")
    
    # Quiz döngüsünü arka planda başlat
    asyncio.create_task(quiz_dongusu())
    
    # Botu çalışır halde tut
    await client.run_until_disconnected()

if __name__ == "__main__":
    asyncio.run(main())
